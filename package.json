{
  "name": "collabnest",
  "version": "1.0.0",
  "description": "Real-Time Collaborative Project Management Tool",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"blue,green\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm -w @collabnest/client run dev",
    "dev:server": "npm -w @collabnest/server run dev",
    "build": "npm run build -ws",
    "build:shared": "npm -w @collabnest/shared run build",
    "build:client": "npm -w @collabnest/client run build",
    "build:server": "npm -w @collabnest/server run build",
    "test": "npm run test -ws --if-present",
    "test:client": "npm -w @collabnest/client run test",
    "test:server": "npm -w @collabnest/server run test",
    "test:jest": "npm run test:jest -ws --if-present",
    "test:jest:client": "npm -w @collabnest/client run test:jest",
    "test:jest:server": "npm -w @collabnest/server run test:jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:report": "playwright show-report",
    "cypress": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:chrome": "cypress run --browser chrome",
    "cypress:run:firefox": "cypress run --browser firefox",
    "lint": "eslint packages --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,css,md}\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "prepare": "husky install",
    "clean": "rimraf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "cypress": "^15.11.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
